# Copy to .env or set in your IDE / OS. Do not commit real values.
# Spring Boot reads these when exported (e.g. PowerShell: $env:STRIPE_SECRET_KEY="sk_test_...")
#
# If the app fails with "Connection to localhost:5432 refused", you are using the default URL.
# Point SPRING_DATASOURCE_URL at Supabase or start PostgreSQL locally. See also:
#   src/main/resources/application-local.properties.example

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_ENABLED=true
STRIPE_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:8080

PEXELS_API_KEY=
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
